{
    "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
    "root": true,
    "vcs": {
        "enabled": true,
        "clientKind": "git",
        "useIgnoreFile": true
    },
    "files": {
        "ignoreUnknown": false,
        "includes": [
            "**/*.ts",
            "**/*.tsx",
            "**/*.js",
            "**/*.jsx",
            "**/*.json",
            "!**/node_modules",
            "!**/node_modules/**/*",
            "!**/dist",
            "!**/dist/**/*",
            "!**/.claude",
            "!**/.claude/**/*",
            "!**/.worktrees",
            "!**/.worktrees/**/*",
            "!**/test-results",
            "!**/test-results/**/*",
            "!gui/build",
            "!gui/build/**/*",
            "!gui/frontend/wailsjs",
            "!gui/frontend/wailsjs/**/*",
            "!gui/frontend/src/lib/wailsjs",
            "!gui/frontend/src/lib/wailsjs/**/*",
            "!config/keyring.json",
            "!config/keyring.lock",
            "!config/settings.json",
            "!config/settings.secrets.json",
            "!config/settings.local.json"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 100
    },
    "linter": {
        "enabled": true,
        "rules": {
            "preset": "recommended",
            "style": {
                "useConst": "error",
                "useTemplate": "error",
                "useShorthandFunctionType": "error",
                "useConsistentArrayType": {
                    "level": "error",
                    "options": {
                        "syntax": "shorthand"
                    }
                }
            },
            "correctness": {
                "useExhaustiveDependencies": "warn",
                "useHookAtTopLevel": "error",
                "noUnusedVariables": "error"
            },
            "suspicious": {
                "noDebugger": "error",
                "noConsole": "warn",
                "noVar": "error",
                "noExplicitAny": "error"
            },
            "complexity": {
                "noExcessiveCognitiveComplexity": {
                    "level": "warn",
                    "options": {
                        "maxAllowedComplexity": 45
                    }
                }
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "quoteProperties": "asNeeded",
            "trailingCommas": "es5",
            "semicolons": "asNeeded",
            "arrowParentheses": "asNeeded"
        }
    },
    "overrides": [
        {
            "includes": ["**/scripts/**/*", "**/tests/**/*", "**/*.test.ts", "**/*.test.tsx"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noConsole": "off"
                    },
                    "style": {
                        "noNonNullAssertion": "off"
                    }
                }
            }
        },
        {
            "includes": ["src/cli/**/*", "bin/**/*"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noConsole": "off"
                    }
                }
            }
        }
    ],
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": "on"
            }
        }
    }
}
