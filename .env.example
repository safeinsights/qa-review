# Copy to .env and fill in real values (never commit .env).
#
# Test accounts are SHARED across all environments (same users everywhere), so
# they are NOT prefixed per-environment. MFA_CODE is the fixed second-factor
# code for those accounts.

ADMIN_EMAIL=si-adm-tester-xxxxx@mailinator.com
ADMIN_PASSWORD=
RESEARCHER_EMAIL=si-research-tester-xxxxx@mailinator.com
RESEARCHER_PASSWORD=
REVIEWER_EMAIL=si-member-tester-xxxxx@mailinator.com
REVIEWER_PASSWORD=
MFA_CODE=424242

# Per-environment base URLs — only the STABLE environments need one.
# PR previews are derived from a PR number (https://pr<N>.qa.safeinsights.org)
# and need NO variable here.
QA_BASE_URL=https://qa.safeinsights.org
STAGING_BASE_URL=https://staging.safeinsights.org
